# ── Application ────────────────────────────────────────────────────
ENVIRONMENT=development        # 'development' or 'production'

# ── Cloudflare R2 Storage ──────────────────────────────────────────
# Get these from the Cloudflare dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=                 # Your Cloudflare Account ID (not email)
R2_ACCESS_KEY_ID=              # R2 API Token — Access Key ID
R2_SECRET_ACCESS_KEY=          # R2 API Token — Secret Access Key
R2_BUCKET_NAME=                # Name of your R2 bucket (e.g. jf-rag-data)

# ── RAG Data & Index Paths ─────────────────────────────────────────
TEXT_DATA_DIR=./data/sample_document
IMAGE_DATA_DIR=./data/sample_image
CSV_DATA_DIR=./data/csv
DATASET_OUTPUT_DIR=./data/dataset
VECTORSTORE_DIR=./vectorstore
FAISS_TEXT_INDEX=./vectorstore/faiss
FAISS_IMAGE_INDEX=./vectorstore/faiss_image
CHROMADB_PATH=./vectorstore/chroma_db
CACHE_DIR=./cache
EMBEDDING_MODEL=intfloat/e5-large-v2
CLIP_MODEL=openai/clip-vit-base-patch32
BLIP_MODEL=Salesforce/blip2-opt-2.7b
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── API / Server ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
UI_PORT=8501
LOG_LEVEL=INFO

# ── LLM Providers ──────────────────────────────────────────────────
GROQ_API_KEYS=                 # Comma-separated Groq API keys
HF_API_TOKEN=                  # Hugging Face token for model downloads
OLLAMA_HOST=http://127.0.0.1:11434

# ── Vision Models ──────────────────────────────────────────────────
LLAMA_VISION_MODEL=moondream   # llama3.2-vision model name in Ollama

# ── Vapi (Voice TTS) ───────────────────────────────────────────────
VITE_VAPI_PUBLIC_KEY=          # Vapi public key (frontend only)

# ── Other ──────────────────────────────────────────────────────────
# Add any other keys your project uses here


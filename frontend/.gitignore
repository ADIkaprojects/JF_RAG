# ============================================================
# FRONTEND (Vite + React + TypeScript) .gitignore
# ============================================================

# ── Build output ────────────────────────────────────────────
dist/                       # Vite production build — generated by `npm run build`
dist-ssr/                   # SSR build output
build/                      # Alternative build dir

# ── Dependencies ────────────────────────────────────────────
node_modules/               # npm/bun packages — restored from package.json

# ── Environment files ───────────────────────────────────────
*.local                     # .env.local, .env.development.local, etc.
.env                        # Should never exist in frontend/ but guard anyway

# ── Type-checking & lint caches ─────────────────────────────
*.tsbuildinfo               # TypeScript incremental build cache
.eslintcache                # ESLint result cache

# ── Vite cache ──────────────────────────────────────────────
.vite/                      # Vite internal cache (pre-bundling)

# ── Test output ─────────────────────────────────────────────
coverage/                   # Vitest/Jest coverage reports

# ── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS & editor noise ───────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json    # Keep shared extension recommendations
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
